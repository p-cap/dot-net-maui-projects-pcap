<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewmodels="clr-namespace:MauiByGeminiOne.ViewModels"
             x:Class="MauiByGeminiOne.MainPage">

    <ContentPage.BindingContext>
        <viewmodels:BookViewModels/>
    </ContentPage.BindingContext>
    <VerticalStackLayout Spacing="20" Padding="30" VerticalOptions="Center">

        <Frame BackgroundColor="{Binding CurrentBook.CoverColor}"
               HeightRequest="200" WidthRequest="150">
            <VerticalStackLayout VerticalOptions="Center">
                <Label Text="{Binding CurrentBook.Title}" 
                       TextColor="White" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                <Label Text="{Binding CurrentBook.Author}" 
                       TextColor="White" HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Frame>

    </VerticalStackLayout>

</ContentPage>